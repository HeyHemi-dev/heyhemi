---
import BaseLayout from "../layouts/BaseLayout.astro";

const intro = {
  title: "Hey Hemi",
  greeting: "Hey, I’m Hemi",
  statement: "I have ideas; I build them.",
};

const projects = [
  {
    name: "With Thanks",
    description: "Effortlessly collect supplier details from couples.",
  },
  {
    name: "Wedding Ready",
    description: "Pinterest, but hyper-local and supplier-lead.",
  },
  {
    name: "Mayday",
    description: "Job board for wedding suppliers during Covid-19.",
  },
  {
    name: "Knowie for Patina Photo",
    description: "Lead and job management, + analytics.",
  },
  {
    name: "Sharesies Open for Sharesies",
    description: "Employee-shares management portal for businesses.",
  },
];

const career = [
  {
    title: "Freelance Developer, Various Projects",
    years: "2024 — now",
  },
  {
    title: "Customer Experience, Xero",
    years: "2025",
  },
  {
    title: "Software Developer Intern, Sharesies",
    years: "2024 — 2025",
  },
  {
    title: "Cert. Applied Software Development, Dev Academy",
    years: "2024",
  },
  {
    title: "Owner & Photographer, Patina Photo",
    years: "2012 — 2024",
  },
  {
    title: "Bachelor of Architectural Studies, Victoria University",
    years: "2008 — 2012",
  },
];

const about = [
  "I always admired builders; the ability to take an idea and turn it into something real. This what I love about software development; creating digital products for people.",
  "I started as an architect, before building my own photographer business (together with my wife), and now I’ve turned to software development. I’m a generalist, self-motivated, and a super-quick learner.",
  "I’m looking to join a team who are passionate about what they are building, that needs someone who can muck in, and is more than just an engineer. If this is you, I’d love to chat.",
];

const contact = ["Email", "Github", "Threads"];
---

<BaseLayout title="Hey Hemi" bodyClass="home-page">
  <main class="home-shell">
    <div class="home-stack">
      <header class="home-intro">
        <h1 class="home-title">{intro.title}</h1>

        <div class="home-copy-group">
          <p class="home-lead">{intro.greeting}</p>
          <p>{intro.statement}</p>
        </div>
      </header>

      <hr class="home-rule" />

      <section class="home-section" aria-labelledby="projects-heading">
        <h2 id="projects-heading" class="home-section-title">Projects</h2>

        <ul class="home-entry-list" role="list">
          {
            projects.map((project) => (
              <li class="home-entry">
                <p class="home-entry-title">{project.name}</p>
                <p class="home-entry-support">{project.description}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="home-rule" />

      <section class="home-section" aria-labelledby="career-heading">
        <h2 id="career-heading" class="home-section-title">Career</h2>

        <ul class="home-entry-list" role="list">
          {
            career.map((item) => (
              <li class="home-entry">
                <p class="home-entry-title">{item.title}</p>
                <p class="home-entry-support">{item.years}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="home-rule" />

      <section class="home-section" aria-labelledby="about-heading">
        <h2 id="about-heading" class="home-section-title">About</h2>

        <div class="home-copy-group">
          {about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <hr class="home-rule" />

      <section class="home-section" aria-labelledby="contact-heading">
        <h2 id="contact-heading" class="home-section-title">Contact</h2>

        <ul class="home-contact-list" role="list">
          {contact.map((item) => <li class="home-contact-item">{item}</li>)}
        </ul>
      </section>
    </div>
  </main>
</BaseLayout>
