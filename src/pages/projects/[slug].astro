---
import type { GetStaticPaths } from "astro";
import Divider from "../../components/Divider.astro";
import ImageBlock from "../../components/ImageBlock.astro";
import ContentBlock from "../../components/ContentBlock.astro";
import List from "../../components/List.astro";
import ListItem from "../../components/ListItem.astro";
import MarkdownBlock from "../../components/MarkdownBlock.astro";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Section from "../../components/Section.astro";
import { allCaseStudies } from "../../data/projects";
import type { CaseStudy } from "../../data/types";

export const getStaticPaths = (() =>
  allCaseStudies.map((caseStudy, index) => ({
    params: { slug: caseStudy.slug },
    props: { caseStudy, index },
  }))) satisfies GetStaticPaths;

const { caseStudy, index } = Astro.props as {
  caseStudy: CaseStudy;
  index: number;
};

const hasProjectLinks = Boolean(caseStudy.liveUrl || caseStudy.repoUrl);

const problem = caseStudy.problemSolution.problem;
const solution = caseStudy.problemSolution.solution;
const techStack = caseStudy.techStack;

const architecture = caseStudy.architecture;
const architectureContent = architecture.content;
const engineering = caseStudy.engineering;
const engineeringRows = engineering.rows;
const deepDive = caseStudy.deepDive;
const caseStudyCount = allCaseStudies.length;

const previous = allCaseStudies[(index - 1 + caseStudyCount) % caseStudyCount]!;
const next = allCaseStudies[(index + 1) % caseStudyCount]!;
---

<ProjectLayout title={`${caseStudy.name} — Case Study`}>
  <main id={caseStudy.slug} class="mx-auto w-full max-w-2xl px-6 pt-12 pb-36">
    <div class="flex flex-col gap-12">
      <header class="flex flex-col gap-12">
        <p class="body-small">
          <a href="/">
            <span class="body-link">Home</span>
          </a>
        </p>
        <div class="flex flex-col gap-6">
          <h1 class="heading-1">{caseStudy.name}</h1>
          <p>{caseStudy.oneLiner}</p>
        </div>

        {
          hasProjectLinks && (
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
              {caseStudy.liveUrl && (
                <p class="body-small">
                  <a
                    href={caseStudy.liveUrl}
                    target="_blank"
                    rel="noreferrer noopener"
                  >
                    <span class="body-link">View Live ↗</span>
                  </a>
                </p>
              )}
              {caseStudy.repoUrl && (
                <p class="body-small">
                  <a
                    href={caseStudy.repoUrl}
                    target="_blank"
                    rel="noreferrer noopener"
                  >
                    <span class="body-link">View GitHub ↗</span>
                  </a>
                </p>
              )}
            </div>
          )
        }

        <List as="div">
          <ListItem as="div" class="flex flex-col gap-3">
            <h2 id="problem-heading" class="heading-3">Problem</h2>
            <MarkdownBlock value={problem} class="body-small" />
          </ListItem>
          <ListItem as="div" class="flex flex-col gap-3">
            <h2 id="solution-heading" class="heading-3">Solution</h2>
            <MarkdownBlock value={solution} class="body-small" />
          </ListItem>
          <ListItem as="div" class="flex flex-col gap-3">
            <h2 id="my-role-heading" class="heading-3">My Role</h2>
            <p class="body-small">{caseStudy.roles.join(", ")}</p>
          </ListItem>
        </List>
      </header>

      <!-- <Section class="gap-6" aria-labelledby="problem-heading">
        <h2 id="problem-heading" class="heading-3">Problem</h2>
        <MarkdownBlock value={problem} />
      </Section>

      <Section class="gap-6" aria-labelledby="solution-heading">
        <h2 id="solution-heading" class="heading-3">Solution</h2>
        <MarkdownBlock value={solution} />
      </Section> -->

      <Divider />

      <Section aria-labelledby="tech-stack-heading">
        <h2 id="tech-stack-heading" class="heading-2">Tech Stack</h2>
        <List>
          {
            techStack.map((item) => (
              <ListItem>
                <MarkdownBlock value={item} />
              </ListItem>
            ))
          }
        </List>
      </Section>

      <Divider />

      <Section aria-labelledby="engineering-heading">
        <div class="flex flex-col gap-6">
          <h2 id="engineering-heading" class="heading-2">Engineering</h2>
          {
            engineering.caption && (
              <p class="body-small">{engineering.caption}</p>
            )
          }
        </div>

        <div
          data-eng-decisions-scroll
          class="border-linework w-full overflow-x-auto overscroll-x-contain border"
        >
          <div class="min-w-4xl overflow-hidden">
            <header class="border-linework grid grid-cols-3 border-b">
              <div class="border-linework border-r px-4 py-3">
                <p class="heading-3">Constraint</p>
              </div>
              <div class="border-linework border-r px-4 py-3">
                <p class="heading-3">Decision</p>
              </div>
              <div class="px-4 py-3">
                <p class="heading-3">Trade-off</p>
              </div>
            </header>

            {
              engineeringRows.map((row, rowIndex) => (
                <article
                  class={`grid grid-cols-3 ${rowIndex < engineeringRows.length - 1 ? "border-linework border-b" : ""}`}
                >
                  <div class="border-linework flex flex-col gap-5 border-r px-4 py-4">
                    <MarkdownBlock value={row.constraint} class="body-small" />
                  </div>
                  <div class="border-linework flex flex-col gap-5 border-r px-4 py-4">
                    <MarkdownBlock value={row.decision} class="body-small" />
                  </div>
                  <div class="flex flex-col gap-5 px-4 py-4">
                    <MarkdownBlock value={row.tradeOff} class="body-small" />
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </Section>

      <Divider />

      <Section aria-labelledby="architecture-heading">
        <div class="flex flex-col gap-6">
          <h2 id="architecture-heading" class="heading-2">Architecture</h2>
          <ImageBlock
            src={architecture.diagram.src}
            alt={architecture.diagram.alt}
            caption={architecture.diagram.caption}
            width={1024}
            height={1536}
          />
        </div>

        {
          architectureContent && (
            <div class="flex flex-col gap-6">
              {architectureContent.map((block) => (
                <ContentBlock block={block} />
              ))}
            </div>
          )
        }
      </Section>

      {
        deepDive && (
          <>
            <Divider />

            <Section aria-labelledby="deep-dive-heading">
              <h2 id="deep-dive-heading" class="heading-2">
                <>
                  <span>Deep Dive:</span>
                  <span>{deepDive.title}</span>
                </>
              </h2>

              <div class="flex flex-col gap-6">
                {deepDive.content.map((block) => (
                  <ContentBlock block={block} />
                ))}
              </div>
            </Section>
          </>
        )
      }

      <Divider />

      <Section aria-labelledby="more-projects-heading">
        <h2 id="more-projects-heading" class="heading-2">More Projects</h2>

        <List class="grid grid-cols-2">
          <ListItem class="col-start-1 flex flex-col gap-3">
            <p class="body-small">Previous</p>
            <a href={`/projects/${previous.slug}`} class="body-link">
              {previous.name}
            </a>
          </ListItem>

          <ListItem
            class="col-start-2 flex flex-col gap-3 justify-self-end text-right"
          >
            <p class="body-small">Next</p>
            <a href={`/projects/${next.slug}`} class="body-link">
              {next.name}
            </a>
          </ListItem>
        </List>
      </Section>
    </div>
  </main>
</ProjectLayout>
